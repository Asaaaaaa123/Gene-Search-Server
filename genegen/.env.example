# Copy to .env.local. Next.js loads .env.local automatically.
NEXT_PUBLIC_API_URL=http://localhost:8050

# Clerk — https://dashboard.clerk.com → API Keys (do not commit real keys in this file)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Same string as your publishable key — Docker/Coolify **runtime** env; used by layout.tsx (Node).
CLERK_PUBLISHABLE_KEY=
# Coolify/Docker: also set NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY as a **build argument** so Edge
# middleware can enforce /upload-csv and /add-gene. Runtime-only keys are not visible to middleware.

# Backend must verify the same sessions: in backend/.env set CLERK_ISSUER (see backend/env.example).
# Optional:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
