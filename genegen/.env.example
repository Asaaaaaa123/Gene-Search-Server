# Copy to .env.local. Next.js loads .env.local automatically.
NEXT_PUBLIC_API_URL=http://localhost:8050

# Clerk — browser sign-in (https://dashboard.clerk.com → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=sk_test_BhJxR1uPpgGk87TTTbd30J2IqfWvAojqp3AQDheLVh
# Docker/Coolify: same value as NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY — readable at runtime on the
# Node server (middleware on Edge still needs NEXT_PUBLIC_* at image build for route protection)
CLERK_PUBLISHABLE_KEY= pk_test_aW50ZXJuYWwtc2VydmFsLTU4LmNsZXJrLmFjY291bnRzLmRldiQ

# Backend must verify the same sessions: in backend/.env set CLERK_ISSUER to this app’s
# Frontend API URL (no trailing slash). See backend/env.example — without it, upload
# and “Customize Theme” server sync return 503.
# Optional; defaults work for most setups:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
