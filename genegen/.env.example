# Local dev: copy to .env.local (Next.js loads it).
#
# Coolify / Docker (when you cannot use Coolify “Environment variables”): edit and commit
# coolify-deploy.env in this folder — the Dockerfile sources it at build and runtime (see
# coolify-deploy.env.example). Do not put production secrets in a public repo.
NEXT_PUBLIC_API_URL=http://localhost:8050

# Clerk — https://dashboard.clerk.com → API Keys (do not commit real keys in this file)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Same string as your publishable key — Docker/Coolify **runtime** env; used by layout.tsx (Node).
CLERK_PUBLISHABLE_KEY=
# Optional: set NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY as a Docker **build argument** if any client
# bundle must embed it; layout prefers CLERK_PUBLISHABLE_KEY at runtime (Coolify env vars).

# Backend must verify the same sessions: in backend/.env set CLERK_ISSUER (see backend/env.example).
# Optional:
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
