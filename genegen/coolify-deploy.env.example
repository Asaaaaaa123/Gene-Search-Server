# Copy to coolify-deploy.env, fill values, commit (private repo only — contains secrets), push.
# Line format: KEY=value (no spaces around =). Use LF line endings, not Windows CRLF.
#
# NEXT_PUBLIC_API_URL must be your FastAPI public base URL (https://...). Never put CLERK_SECRET_KEY (sk_...) here.

NEXT_PUBLIC_API_URL=https://your-api.example.com

# Clerk — same publishable key in both lines
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
