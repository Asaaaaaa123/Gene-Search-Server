# Copy to .env in the repo root, then: docker compose up -d --build
# For production: docker compose -f docker-compose.prod.yml up -d --build

# --- Backend ---
PORT=8000
BACKEND_PUBLISH_PORT=8000
WORKERS=1
MONGODB_URI=
CLERK_ISSUER=
VALID_TOKENS=

# --- Frontend (build-time + runtime) ---
FRONTEND_PUBLISH_PORT=3000
# Same-origin /api/* is proxied by Next.js to this URL (build-time rewrite).
# Docker Compose (both services on one host): use internal service name.
NEXT_PUBLIC_API_URL=http://backend:8000
# Split public API URL (browser links to /docs, etc.) — set when API has its own domain.
# NEXT_PUBLIC_API_PUBLIC_URL=https://api.yourdomain.com

# Clerk — same application as backend CLERK_ISSUER (Dashboard → API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
CLERK_PUBLISHABLE_KEY=pk_test_CHANGE_ME
CLERK_SECRET_KEY=sk_test_CHANGE_ME
