# Copy to .env next to server.py. FastAPI reads this file on startup (see server.py load_dotenv).

# --- CORS (required when the Next.js app is on another host, e.g. Coolify) ---
# Comma-separated list, no trailing slashes. Example: your public frontend URL.
# CORS_ALLOWED_ORIGINS=https://asagene.aurorarangers.ca
#
# Without this, the browser shows "NetworkError when attempting to fetch resource" because
# only http(s)://localhost and 127.0.0.1 are allowed by default.

# --- MongoDB (optional for search fallbacks; required for CSV/Excel upload upserts) ---
MONGODB_URI=mongodb://localhost:27017/gene_search_db

# --- Clerk JWT verification (required for signed-in API: upload, add-gene, /api/user/preferences) ---
# Use the SAME Clerk application as the Next.js app (genegen/.env.local).
#
# Clerk Dashboard shows several URLs — only one belongs in CLERK_ISSUER:
#
#   Frontend API URL (e.g. https://internal-serval-58.clerk.accounts.dev)
#     → Set as CLERK_ISSUER below (no trailing slash). This is the JWT issuer for session tokens.
#
#   JWKS URL (e.g. …/clerk.accounts.dev/.well-known/jwks.json)
#     → Optional. This backend defaults to {CLERK_ISSUER}/.well-known/jwks.json — set
#       CLERK_JWKS_URL only if yours differs.
#
#   https://api.clerk.com (“Backend API” in some docs)
#     → Do NOT use as CLERK_ISSUER. That host is Clerk’s REST API, not the issuer on user JWTs.
#
# Example (internal-serval-58):
#   CLERK_ISSUER=https://internal-serval-58.clerk.accounts.dev
#   # CLERK_JWKS_URL=   ← omit; same as https://internal-serval-58.clerk.accounts.dev/.well-known/jwks.json
#
# Do NOT put these in backend/.env (Next.js only):
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY  → genegen/.env.local
CLERK_ISSUER=
# CLERK_JWKS_URL=
